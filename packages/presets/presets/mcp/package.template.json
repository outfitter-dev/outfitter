{
  "name": "{{packageName}}",
  "version": "{{version}}",
  "description": "{{description}}",
  "keywords": [
    "bun",
    "mcp",
    "model-context-protocol",
    "outfitter",
    "typescript"
  ],
  "license": "MIT",
  "bin": {
    "{{binName}}": "./dist/server.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/server.ts --outdir dist --target bun && bun build src/index.ts --outdir dist --target bun --sourcemap && tsc --emitDeclarationOnly --outDir dist",
    "dev": "bun --watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "verify:ci": "bun run typecheck && bun run check && bun run build && bun run test",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "clean:artifacts": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@outfitter/contracts": "workspace:*",
    "@outfitter/logging": "workspace:*",
    "@outfitter/mcp": "workspace:*",
    "@outfitter/types": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@outfitter/testing": "workspace:*"
  },
  "outfitter": {
    "template": {
      "kind": "runnable",
      "placement": "apps",
      "surfaces": ["mcp"]
    }
  }
}
