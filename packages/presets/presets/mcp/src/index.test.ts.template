import { describe, expect, test } from "bun:test";

import { createContext } from "@outfitter/contracts";

import { server } from "./mcp.js";
import { helloTool } from "./tools/hello.js";

describe("server", () => {
  test("registers the hello tool", () => {
    const registered = server.getTools().some((tool) => tool.name === "hello");

    expect(registered).toBe(true);
  });
});

describe("versionResource", () => {
  test("version resource is registered", () => {
    const harness = createMcpHarness(server);
    const resources = harness.listResources();
    const registered = resources.some((r) => r.name === "Server Version");

    expect(registered).toBe(true);
  });
});

describe("helloTool", () => {
  const ctx = createContext({ cwd: process.cwd(), env: process.env });

  test("returns greeting for valid input", async () => {
    const result = await helloTool.handler({ name: "Outfitter" }, ctx);

    expect(result.isOk()).toBe(true);
    if (result.isErr()) return;
    expect(result.value.greeting).toBe("Hello, Outfitter!");
  });

  test("returns greeting with default name", async () => {
    const result = await helloTool.handler({ name: "World" }, ctx);

    expect(result.isOk()).toBe(true);
    if (result.isErr()) return;
    expect(result.value.greeting).toBe("Hello, World!");
  });
});
