import { describe, expect, test } from "bun:test";
import { tmpdir } from "node:os";
import { join } from "node:path";

import { acquireDaemonLock, releaseDaemonLock } from "@outfitter/daemon";

import { runDaemon } from "./index.js";

describe("daemon", () => {
  test("exports the daemon entrypoint", () => {
    expect(typeof runDaemon).toBe("function");
  });

  test("acquires and releases a lock", async () => {
    const lockPath = join(tmpdir(), `test-daemon-${Date.now()}.lock`);
    const result = await acquireDaemonLock(lockPath);

    expect(result.isOk()).toBe(true);
    if (result.isErr()) return;

    const lock = result.value;
    await releaseDaemonLock(lock);

    // Lock should be released — acquiring again should succeed
    const secondResult = await acquireDaemonLock(lockPath);
    expect(secondResult.isOk()).toBe(true);
    if (secondResult.isOk()) {
      await releaseDaemonLock(secondResult.value);
    }
  });
});
